generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Schedule {
  id        Int      @id @default(autoincrement())
  course    Int
  group     String
  groupFull String
  specialty String
  dayOfWeek String
  timeSlot  String
  subject   String
  teacher   String
  room      String?
  weekType  String   @default("both")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([course, groupFull, dayOfWeek, timeSlot])
  @@index([course, group])
  @@index([teacher])
  @@index([groupFull])
}

model Teacher {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Replacement {
  id              Int      @id @default(autoincrement())
  date            String // Дата замены в формате "YYYY-MM-DD"
  course          Int
  groupFull       String
  pairNumber      Int // Номер пары (1-4)
  originalSubject String?
  newSubject      String
  originalTeacher String?
  newTeacher      String
  room            String?
  notes           String? // Дополнительные заметки
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([date, groupFull, pairNumber])
  @@index([date])
  @@index([groupFull])
  @@index([course])
}
