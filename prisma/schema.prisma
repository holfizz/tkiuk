generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Schedule {
  id        Int      @id @default(autoincrement())
  course    Int
  group     String
  groupFull String
  specialty String
  dayOfWeek String
  timeSlot  String
  subject   String
  teacher   String
  room      String?
  weekType  String   @default("both")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([course, group])
  @@index([teacher])
  @@index([groupFull])
  @@index([weekType])
  @@index([course, groupFull, dayOfWeek, timeSlot, weekType])
}

model Teacher {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Replacement {
  id              Int      @id @default(autoincrement())
  date            String
  course          Int
  groupFull       String
  pairNumber      Int
  originalSubject String?
  newSubject      String
  originalTeacher String?
  newTeacher      String
  room            String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([date, groupFull, pairNumber])
  @@index([date])
  @@index([groupFull])
  @@index([course])
}

model WeekSettings {
  id              Int      @id @default(autoincrement())
  currentWeekType String   @default("numerator")
  startDate       String?
  updatedAt       DateTime @updatedAt
}
